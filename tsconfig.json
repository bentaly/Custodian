{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    // Type-checking only — the app is built by Vite, never by tsc. Prevents a bare
    // `tsc` (without --noEmit) from littering compiled .js next to the .ts sources.
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "drizzle", "scripts", "vite.config.ts", "drizzle.config.ts"]
}
